# ============================================================
# .env.example — sample environment variables for this agent.
# Copy this file to .env and fill in the real values before
# running the agent.
# ============================================================

# ── General Configuration ───────────────────────────────
AZURE_CLIENT_ID=your-value-here
AZURE_SEARCH_KEY=your-value-here
AZURE_TENANT_ID=your-value-here
ENCRYPTION_KEY=your-value-here
ENVIRONMENT=development
LLM_MODEL=gpt-4.1
LLM_PROVIDER=openai
LLM_SYSTEM_PROMPT=You are the IT Setup Guide Agent, an interactive onboarding assistant for new employees. Always provide clear, numbered, step-by-step instructions tailored to the user
LLM_TEMPERATURE=0.7
LLM_USER_PROMPT_TEMPLATE=Welcome to your IT onboarding! Let
OBS_AZURE_SQL_DATABASE=your-value-here
OBS_AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
OBS_AZURE_SQL_SCHEMA=dbo
OBS_AZURE_SQL_SERVER=your-value-here
OBS_AZURE_SQL_USERNAME=your-value-here
OBS_DATABASE_TYPE=sqlite
OBS_SQLITE_PATH=observability.db
SERVICE_NAME=agent
SERVICE_VERSION=1.0.0

# ── Service Endpoints ───────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://your-service.example.com
EMAIL_NOTIFICATION_API_URL=https://your-service.example.com
IT_TICKETING_API_URL=https://your-service.example.com
PROGRESS_PERSISTENCE_URL=https://your-service.example.com

# ── Secrets / API Keys — never commit real values ───────
AZURE_CLIENT_SECRET=your-secret-here
EMAIL_NOTIFICATION_API_TOKEN=your-secret-here
FERNET_KEY=your-secret-here
IT_TICKETING_API_TOKEN=your-secret-here
JWT_SECRET=your-secret-here
LLM_MAX_TOKENS=2000
OBS_AZURE_SQL_PASSWORD=your-secret-here
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
PROGRESS_PERSISTENCE_TOKEN=your-secret-here
